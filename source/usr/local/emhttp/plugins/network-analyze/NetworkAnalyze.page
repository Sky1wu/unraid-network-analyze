---
<?php
$docroot = $docroot ?? $_SERVER['DOCUMENT_ROOT'] ?: '/usr/local/emhttp';
parse_plugin('network-analyze');
?>
<link type="text/css" rel="stylesheet" href="/plugins/network-analyze/css/network-analyze.css">

<div class="network-analyze">

  <!-- Interface Summary Bar -->
  <div class="na-iface-bar" id="na-iface-bar"></div>

  <!-- Toolbar -->
  <div class="na-toolbar">
    <div class="na-tabs">
      <button class="na-tab active" data-tab="processes">_(Processes)_</button>
      <button class="na-tab" data-tab="connections">_(Connections)_</button>
    </div>
    <div class="na-controls">
      <span class="na-status" id="na-status">_(Live · 2s)_</span>
      <button id="na-pause" class="na-btn" title="_(Pause / Resume)_">_(Pause)_</button>
    </div>
  </div>

  <!-- Namespace Filter Bar -->
  <div class="na-ns-filter-bar" id="na-ns-filter-bar">
    <span class="na-ns-filter-label">_(Namespace:)_</span>
    <div id="na-ns-filters" class="na-ns-filter-list"></div>
  </div>

  <!-- Processes Tab -->
  <div class="na-panel active" id="panel-processes">
    <table class="na-table" id="process-table">
      <thead>
        <tr>
          <th data-col="comm" class="sortable">_(Process)_</th>
          <th data-col="pid" class="sortable">PID</th>
          <th data-col="ns_label" class="sortable">_(Namespace)_</th>
          <th data-col="socket_count" class="sortable">_(Socket Count)_</th>
          <th data-col="io_rx_rate" class="sortable" title="_(Process read rate (includes disk reads + network receive, cannot isolate network-only))_">_(Read I/O Rate)_</th>
          <th data-col="io_tx_rate" class="sortable" title="_(Process write rate (includes disk writes + network send, cannot isolate network-only))_">_(Write I/O Rate)_</th>
          <th data-col="connections">_(Connections)_</th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
    <div class="na-detail" id="process-detail" style="display:none"></div>
  </div>

  <!-- Connections Tab -->
  <div class="na-panel" id="panel-connections">
    <div class="na-filters">
      <select id="filter-protocol">
        <option value="all">_(All Protocols)_</option>
        <option value="tcp">TCP</option>
        <option value="tcp6">TCP6</option>
        <option value="udp">UDP</option>
        <option value="udp6">UDP6</option>
      </select>
      <select id="filter-state">
        <option value="all">_(All States)_</option>
        <option value="ESTABLISHED">ESTABLISHED</option>
        <option value="LISTEN">LISTEN</option>
        <option value="TIME_WAIT">TIME_WAIT</option>
        <option value="CLOSE_WAIT">CLOSE_WAIT</option>
        <option value="SYN_SENT">SYN_SENT</option>
      </select>
      <input type="text" id="filter-search" placeholder="_(Search IP, port, process...)_">
      <label class="na-checkbox">
        <input type="checkbox" id="filter-hide-timewait"> _(Hide TIME_WAIT)_
      </label>
    </div>
    <table class="na-table" id="connection-table">
      <thead>
        <tr>
          <th data-col="process" class="sortable">_(Process)_</th>
          <th data-col="pid" class="sortable">PID</th>
          <th data-col="protocol" class="sortable">_(Protocol)_</th>
          <th data-col="local_addr" class="sortable">_(Local Address)_</th>
          <th data-col="remote_addr" class="sortable">_(Remote Address)_</th>
          <th data-col="state" class="sortable">_(State)_</th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
  </div>

</div>

<script>
var _NA_I18N = {
  'Pause': '_(Pause)_',
  'Resume': '_(Resume)_',
  'Paused': '_(Paused)_',
  'Live · 2s': '_(Live · 2s)_',
  'Protocol': '_(Protocol)_',
  'Local': '_(Local)_',
  'Remote': '_(Remote)_',
  'State': '_(State)_',
  'Showing first 20 connections, switch to "Connections" tab for the full list.': '_(Showing first 20 connections, switch to "Connections" tab for the full list.)_',
  'No processes with network activity found': '_(No processes with network activity found)_',
  'Showing first {n} processes (of {total}, sorted by socket count)': '_(Showing first {n} processes (of {total}, sorted by socket count))_',
  'No connections match current filters': '_(No connections match current filters)_',
  'Showing first {n} connections (of {total})': '_(Showing first {n} connections (of {total}))_',
  'No network interfaces detected': '_(No network interfaces detected)_'
};
function _(key) { return _NA_I18N[key] !== undefined ? _NA_I18N[key] : key; }
</script>
<script src="/plugins/network-analyze/js/network-analyze.js"></script>
